# Copy to ".env" and adjust. Docker Compose also reads POSTGRES_* from the host environment.

# --- Django ---
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://your-domain.example

# --- Database ---
# Local SQLite if unset. For Postgres (Docker / Neon / cloud):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
DB_CONN_MAX_AGE=0

# --- Docker Compose (local Postgres) ---
POSTGRES_PASSWORD=flixbd_local_dev
POSTGRES_PORT=5432

# --- Scraping / proxy ---
SCRAPE_PROXY=
# Route Google Gemini API through SCRAPE_PROXY (true/false)
GOOGLE_LLM_USE_PROXY=True

# --- Django-Q2 workers (host process; set before starting qcluster) ---
Q_CLUSTER_WORKERS=1

# --- LLM (optional; unset = no extra params; same as before these features existed) ---
#
# 1) GEMINI_THINKING_LEVEL — Google Gemini API only (LLMConfig.sdk = google).
#    Use when your model id is Gemini 3.x (e.g. gemini-3-flash). Maps to ThinkingConfig.thinking_level.
#    Values: MINIMAL | LOW | MEDIUM | HIGH (see Gemini "thinking" docs).
#    Do not set together with GEMINI_THINKING_BUDGET; if both are set in env, LEVEL is used.
GEMINI_THINKING_LEVEL=MINIMAL
#
# 2) GEMINI_THINKING_BUDGET — Google Gemini API only (LLMConfig.sdk = google).
#    Use when your model id is Gemini 2.5 (e.g. gemini-2.5-flash, gemini-2.5-pro). Maps to ThinkingConfig.thinking_budget.
#    Typical: 0 = disable where supported; -1 = dynamic budget. Model-specific limits apply (Pro may not allow 0).
#    Leave unset if you use Gemini 3 with thinking_level instead.
GEMINI_THINKING_BUDGET=0
#
# 3) OPENAI_REASONING_EFFORT — OpenAI-compatible Chat Completions only (LLMConfig.sdk = openai).
#    Use for reasoning-capable models (e.g. o-series, some gpt-5 family). Passed as reasoning_effort on chat.completions.
#    Typical low-latency extraction: none | minimal | low (model must support the value).
#    Omit for normal non-reasoning models (gpt-4o, etc.) and for Mistral SDK path.
OPENAI_REASONING_EFFORT=none

# --- Pydoll / browser scraping ---
# PYDOLL_CDP_PORT=9222
# PYDOLL_RESTART_COALESCE_SEC=1.0
# PYDOLL_MAX_PARALLEL_TABS=4

# --- Screenshots (ffmpeg) ---
# SCREENSHOT_FFMPEG_HWACCEL=auto
# SCREENSHOT_FFMPEG_EXTRA_FFLAGS=

# --- Upload pipeline: force adult flag by source domain label (comma-separated). Unset = built-in defaults.
# Set empty to disable: FORCE_IS_ADULT_SOURCE_ROOT_DOMAIN_LABELS=
# FORCE_IS_ADULT_SOURCE_ROOT_DOMAIN_LABELS=examplelabel

# --- Scripts only (optional) ---
# MISTRAL_API_KEY=
# MISTRAL_MODEL=
